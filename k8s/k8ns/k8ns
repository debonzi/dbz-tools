#!/usr/bin/env bash
set -euo pipefail

kubectl_bin="${KUBECTL:-kubectl}"

usage() {
    cat <<'USAGE'
Usage:
  k8ns                List namespaces in the current context
  k8ns <namespace>    Set namespace for the current context
  k8ns -h|--help      Show this help
USAGE
}

if [ "$#" -gt 1 ]; then
    usage >&2
    exit 2
fi

case "${1:-}" in
    -h|--help)
        usage
        exit 0
        ;;
    "")
        "$kubectl_bin" get namespaces
        ;;
    *)
        "$kubectl_bin" config set-context --current --namespace "$1"
        ;;
esac
